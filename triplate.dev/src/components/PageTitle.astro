---
/**
 * Custom Starlight page title. On the home page (root slug) the title is
 * rendered as a large dictionary entry; every other page keeps the default
 * heading. The element keeps Starlight's `_top` id so in-page anchors work.
 */
const route = Astro.locals.starlightRoute;
const isHome = route.slug === '';
const title = route.entry.data.title;
---

{
  isHome ? (
    <>
      <img class="triplate-masthead" src={`${import.meta.env.BASE_URL}/masthead.png`} alt="" />
      <h1 id="_top" class="triplate-entry">
        <span class="tl-word">triplate</span><span class="tl-pos">, to</span>
        <span class="tl-op">:=</span>
        <span class="tl-def">safely template RDF languages with ease</span>
      </h1>
    </>
  ) : (
    <h1 id="_top">{title}</h1>
  )
}

<style>
  .triplate-masthead {
    display: block;
    width: 100%;
    height: auto;
    margin-top: 1rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  h1 {
    margin-top: 1rem;
    font-size: var(--sl-text-h1);
    line-height: var(--sl-line-height-headings);
    font-weight: 600;
    color: var(--sl-color-white);
  }
</style>
